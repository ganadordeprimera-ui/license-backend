# Copia este archivo como ".env" para desarrollo local (no subas el .env real a git)

# Puerto local (Render lo asigna automáticamente en producción, esta variable
# es solo para cuando corras el servidor en tu propia PC)
PORT=3000

# Clave secreta para proteger los endpoints /api/admin/*.
# Inventa una clave larga y aleatoria, por ejemplo usando:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# (Opcional) Restringe qué origen puede llamar a la API.
# El ID de una extensión de Chrome se ve como: chrome-extension://abcdefghijklmnopabcdefghijklmnop
# Puedes dejarlo vacío mientras pruebas, y restringirlo cuando ya tengas el
# ID final de tu extensión publicada.
# ALLOWED_ORIGIN=chrome-extension://TU_ID_DE_EXTENSION_AQUI
